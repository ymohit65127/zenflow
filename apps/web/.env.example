# =============================================================================
# ZenFlow Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ZenFlow

# Database (Docker: postgres://zenflow:zenflow_secret@localhost:5432/zenflow)
DATABASE_URL=postgresql://zenflow:zenflow_secret@localhost:5432/zenflow

# Auth.js
AUTH_SECRET=your-super-secret-key-at-least-32-chars-change-this
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Entra ID (https://portal.azure.com)
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=
MICROSOFT_ENTRA_TENANT_ID=

# Redis (Docker: redis://:zenflow_redis@localhost:6379)
REDIS_URL=redis://:zenflow_redis@localhost:6379

# MinIO (Docker)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=zenflow_minio
MINIO_SECRET_KEY=zenflow_minio_secret
MINIO_BUCKET=zenflow
MINIO_USE_SSL=false

# Email (Docker Mailhog SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@zenflow.io
# SMTP_USER=
# SMTP_PASS=
