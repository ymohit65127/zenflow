model HrDepartment {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String   @db.Uuid
  name                 String   @db.VarChar(100)
  description          String?  @db.Text
  head_employee_id     String?  @db.Uuid
  parent_department_id String?  @db.Uuid
  cost_center_code     String?  @db.VarChar(50)
  budget_amount        Decimal? @db.Decimal(15, 2)
  headcount            Int      @default(0)
  position             Int      @default(0)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  organization Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  parent       HrDepartment?   @relation("DeptHierarchy", fields: [parent_department_id], references: [id])
  children     HrDepartment[]  @relation("DeptHierarchy")
  employees    HrEmployee[]
  job_postings HrJobPosting[]
  designations HrDesignation[]

  @@index([organization_id])
  @@index([parent_department_id])
  @@map("hr_departments")
}

