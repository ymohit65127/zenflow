// ZenFlow — Complete Database Schema
// 98 tables across 13 modules
// Generated: 2026-05-27 | Author: Mohit Yadav

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// MODULE 1 — CORE PLATFORM (Organizations, Auth, RBAC, Billing, Audit)
// =============================================================================

model Organization {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String    @unique
  domain          String?
  logo_url        String?
  timezone        String    @default("UTC")
  locale          String    @default("en")
  currency        String    @default("USD")
  plan            PlanType  @default(FREE)
  plan_expires_at DateTime?
  max_users       Int       @default(5)
  is_active       Boolean   @default(true)
  settings        Json      @default("{}")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  // Relations
  users                  User[]
  roles                  Role[]
  invitations            Invitation[]
  subscriptions          Subscription[]
  audit_logs             AuditLog[]
  crm_contacts           CrmContact[]
  crm_leads              CrmLead[]
  crm_deals              CrmDeal[]
  crm_pipelines          CrmPipeline[]
  crm_activities         CrmActivity[]
  forms                  Form[]
  projects               Project[]
  tasks                  Task[]
  employees              Employee[]
  tickets                Ticket[]
  invoices               Invoice[]
  products               Product[]
  workflows              Workflow[]
  documents              Document[]
  channels               Channel[]
  integrations           Integration[]
  webhooks               Webhook[]
  api_keys               ApiKey[]
  custom_fields          CustomField[]
  notifications          Notification[]
  dashboard_widgets      DashboardWidget[]
  analytics_reports      AnalyticsReport[]
  saved_filters          SavedFilter[]
  knowledge_base_articles KnowledgeBaseArticle[]

  @@index([slug])
  @@index([plan])
  @@map("organizations")
}

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String    @db.Uuid
  email             String
  email_verified    Boolean   @default(false)
  password_hash     String?
  name              String
  avatar_url        String?
  phone             String?
  timezone          String    @default("UTC")
  locale            String    @default("en")
  is_active         Boolean   @default(true)
  is_owner          Boolean   @default(false)
  two_factor_secret String?
  two_factor_enabled Boolean  @default(false)
  last_login_at     DateTime?
  last_login_ip     String?
  login_count       Int       @default(0)
  metadata          Json      @default("{}")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  // Relations
  organization          Organization          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  sessions              Session[]
  accounts              Account[]
  user_roles            UserRole[]
  audit_logs            AuditLog[]
  crm_activities        CrmActivity[]         @relation("ActivityOwner")
  assigned_leads        CrmLead[]             @relation("LeadAssignee")
  assigned_deals        CrmDeal[]             @relation("DealAssignee")
  owned_projects        Project[]             @relation("ProjectOwner")
  task_assignments      TaskAssignment[]
  created_tasks         Task[]                @relation("TaskCreator")
  leave_requests        LeaveRequest[]
  ticket_assignments    TicketAssignment[]
  created_tickets       Ticket[]              @relation("TicketCreator")
  channel_memberships   ChannelMember[]
  chat_messages         ChatMessage[]
  document_shares       DocumentShare[]
  notifications         Notification[]
  created_workflows     Workflow[]            @relation("WorkflowCreator")
  form_submissions      FormSubmission[]      @relation("SubmissionUser")

  @@unique([organization_id, email])
  @@index([organization_id])
  @@index([email])
  @@map("users")
}

model Session {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  token         String   @unique
  ip_address    String?
  user_agent    String?
  expires_at    DateTime
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@map("sessions")
}

model Account {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String  @db.Uuid
  provider            String
  provider_account_id String
  access_token        String?
  refresh_token       String?
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@index([user_id])
  @@map("accounts")
}

model Role {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String
  description     String?
  is_system       Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user_roles       UserRole[]
  role_permissions RolePermission[]

  @@unique([organization_id, name])
  @@index([organization_id])
  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String
  resource    String
  action      String
  description String?
  created_at  DateTime @default(now())

  role_permissions RolePermission[]

  @@unique([module, resource, action])
  @@map("permissions")
}

model UserRole {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String @db.Uuid
  role_id String @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id])
  @@map("user_roles")
}

model RolePermission {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String @db.Uuid
  permission_id String @db.Uuid

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model Invitation {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  email           String
  role_id         String?          @db.Uuid
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expires_at      DateTime
  created_at      DateTime         @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([token])
  @@map("invitations")
}

model Subscription {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String             @db.Uuid
  plan            PlanType
  status          SubscriptionStatus @default(ACTIVE)
  billing_cycle   BillingCycle       @default(MONTHLY)
  amount          Decimal            @db.Decimal(10, 2)
  currency        String             @default("USD")
  started_at      DateTime           @default(now())
  expires_at      DateTime?
  cancelled_at    DateTime?
  payment_method  String?
  external_id     String?
  metadata        Json               @default("{}")
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("subscriptions")
}

model AuditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String?  @db.Uuid
  action          String
  resource_type   String
  resource_id     String?
  old_values      Json?
  new_values      Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([user_id])
  @@index([resource_type, resource_id])
  @@index([created_at])
  @@map("audit_logs")
}

model ApiKey {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String
  key_hash        String    @unique
  key_prefix      String
  scopes          String[]
  last_used_at    DateTime?
  expires_at      DateTime?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("api_keys")
}

model CustomField {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  module          String
  entity_type     String
  label           String
  field_key       String
  field_type      CustomFieldType
  options         Json?
  is_required     Boolean         @default(false)
  sort_order      Int             @default(0)
  created_at      DateTime        @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, module, entity_type, field_key])
  @@index([organization_id])
  @@map("custom_fields")
}

model Notification {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  user_id         String           @db.Uuid
  type            String
  title           String
  body            String?
  data            Json             @default("{}")
  is_read         Boolean          @default(false)
  read_at         DateTime?
  created_at      DateTime         @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([organization_id, user_id])
  @@index([is_read])
  @@map("notifications")
}

// =============================================================================
// MODULE 2 — CRM
// =============================================================================

model CrmContact {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  first_name      String
  last_name       String?
  email           String?
  phone           String?
  mobile          String?
  company         String?
  title           String?
  department      String?
  website         String?
  linkedin_url    String?
  twitter_handle  String?
  address_line1   String?
  address_line2   String?
  city            String?
  state           String?
  postal_code     String?
  country         String?
  tags            String[]
  source          String?
  status          ContactStatus @default(ACTIVE)
  custom_fields   Json      @default("{}")
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  organization Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  leads        CrmLead[]
  deals        CrmDeal[]     @relation("DealContact")
  activities   CrmActivity[]

  @@index([organization_id])
  @@index([email])
  @@map("crm_contacts")
}

model CrmPipeline {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String
  description     String?
  is_default      Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  stages       CrmPipelineStage[]
  deals        CrmDeal[]

  @@index([organization_id])
  @@map("crm_pipelines")
}

model CrmPipelineStage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipeline_id String   @db.Uuid
  name        String
  sort_order  Int      @default(0)
  color       String   @default("#6366f1")
  win_probability Decimal? @db.Decimal(5, 2)
  is_closed   Boolean  @default(false)
  is_won      Boolean  @default(false)
  created_at  DateTime @default(now())

  pipeline CrmPipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  deals    CrmDeal[]

  @@index([pipeline_id])
  @@map("crm_pipeline_stages")
}

model CrmLead {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String      @db.Uuid
  contact_id      String?     @db.Uuid
  assignee_id     String?     @db.Uuid
  title           String
  company         String?
  email           String?
  phone           String?
  source          LeadSource?
  status          LeadStatus  @default(NEW)
  score           Int         @default(0)
  estimated_value Decimal?    @db.Decimal(15, 2)
  currency        String      @default("USD")
  notes           String?
  custom_fields   Json        @default("{}")
  converted_at    DateTime?
  converted_deal_id String?   @db.Uuid
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  deleted_at      DateTime?

  organization Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  contact      CrmContact?   @relation(fields: [contact_id], references: [id])
  assignee     User?         @relation("LeadAssignee", fields: [assignee_id], references: [id])
  activities   CrmActivity[]

  @@index([organization_id])
  @@index([assignee_id])
  @@map("crm_leads")
}

model CrmDeal {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String     @db.Uuid
  pipeline_id     String     @db.Uuid
  stage_id        String     @db.Uuid
  contact_id      String?    @db.Uuid
  assignee_id     String?    @db.Uuid
  name            String
  value           Decimal?   @db.Decimal(15, 2)
  currency        String     @default("USD")
  probability     Decimal?   @db.Decimal(5, 2)
  expected_close  DateTime?
  closed_at       DateTime?
  lost_reason     String?
  status          DealStatus @default(OPEN)
  tags            String[]
  notes           String?
  custom_fields   Json       @default("{}")
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  deleted_at      DateTime?

  organization Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  pipeline     CrmPipeline      @relation(fields: [pipeline_id], references: [id])
  stage        CrmPipelineStage @relation(fields: [stage_id], references: [id])
  contact      CrmContact?      @relation("DealContact", fields: [contact_id], references: [id])
  assignee     User?            @relation("DealAssignee", fields: [assignee_id], references: [id])
  activities   CrmActivity[]

  @@index([organization_id])
  @@index([pipeline_id, stage_id])
  @@map("crm_deals")
}

model CrmActivity {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  owner_id        String       @db.Uuid
  contact_id      String?      @db.Uuid
  lead_id         String?      @db.Uuid
  deal_id         String?      @db.Uuid
  type            ActivityType
  subject         String
  description     String?
  status          ActivityStatus @default(PLANNED)
  priority        Priority     @default(MEDIUM)
  due_at          DateTime?
  completed_at    DateTime?
  duration_min    Int?
  location        String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  owner        User         @relation("ActivityOwner", fields: [owner_id], references: [id])
  contact      CrmContact?  @relation(fields: [contact_id], references: [id])
  lead         CrmLead?     @relation(fields: [lead_id], references: [id])
  deal         CrmDeal?     @relation(fields: [deal_id], references: [id])

  @@index([organization_id])
  @@index([owner_id])
  @@map("crm_activities")
}

// =============================================================================
// MODULE 3 — FORMS BUILDER
// =============================================================================

model Form {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String    @db.Uuid
  title             String
  description       String?
  slug              String
  status            FormStatus @default(DRAFT)
  is_public         Boolean   @default(true)
  requires_auth     Boolean   @default(false)
  close_on_limit    Boolean   @default(false)
  submission_limit  Int?
  close_at          DateTime?
  success_message   String?
  redirect_url      String?
  notification_emails String[]
  settings          Json      @default("{}")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  organization Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  fields       FormField[]
  submissions  FormSubmission[]

  @@unique([organization_id, slug])
  @@index([organization_id])
  @@map("forms")
}

model FormField {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id      String        @db.Uuid
  parent_id    String?       @db.Uuid
  type         FormFieldType
  label        String
  placeholder  String?
  description  String?
  field_key    String
  is_required  Boolean       @default(false)
  is_hidden    Boolean       @default(false)
  sort_order   Int           @default(0)
  options      Json?
  validations  Json?
  conditions   Json?
  settings     Json          @default("{}")
  created_at   DateTime      @default(now())

  form   Form        @relation(fields: [form_id], references: [id], onDelete: Cascade)
  parent FormField?  @relation("FieldHierarchy", fields: [parent_id], references: [id])
  children FormField[] @relation("FieldHierarchy")

  @@index([form_id])
  @@map("form_fields")
}

model FormSubmission {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id         String    @db.Uuid
  user_id         String?   @db.Uuid
  data            Json
  ip_address      String?
  user_agent      String?
  referrer        String?
  is_complete     Boolean   @default(true)
  submitted_at    DateTime  @default(now())

  form Form  @relation(fields: [form_id], references: [id], onDelete: Cascade)
  user User? @relation("SubmissionUser", fields: [user_id], references: [id])

  @@index([form_id])
  @@index([submitted_at])
  @@map("form_submissions")
}

// =============================================================================
// MODULE 4 — ANALYTICS & DASHBOARDS
// =============================================================================

model DashboardWidget {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String      @db.Uuid
  user_id         String?     @db.Uuid
  title           String
  widget_type     WidgetType
  data_source     String
  query_config    Json        @default("{}")
  display_config  Json        @default("{}")
  grid_col        Int         @default(0)
  grid_row        Int         @default(0)
  grid_w          Int         @default(4)
  grid_h          Int         @default(3)
  refresh_interval_sec Int?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("dashboard_widgets")
}

model AnalyticsReport {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  name            String
  description     String?
  module          String
  report_type     ReportType
  config          Json         @default("{}")
  is_scheduled    Boolean      @default(false)
  schedule_cron   String?
  last_run_at     DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("analytics_reports")
}

model SavedFilter {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String?  @db.Uuid
  module          String
  entity_type     String
  name            String
  filters         Json
  is_shared       Boolean  @default(false)
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("saved_filters")
}

// =============================================================================
// MODULE 5 — PROJECT MANAGEMENT
// =============================================================================

model Project {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  owner_id        String        @db.Uuid
  name            String
  description     String?
  status          ProjectStatus @default(ACTIVE)
  color           String        @default("#6366f1")
  icon            String?
  start_date      DateTime?
  due_date        DateTime?
  completed_at    DateTime?
  settings        Json          @default("{}")
  is_archived     Boolean       @default(false)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  deleted_at      DateTime?

  organization Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  owner        User           @relation("ProjectOwner", fields: [owner_id], references: [id])
  members      ProjectMember[]
  task_lists   TaskList[]
  tasks        Task[]
  milestones   Milestone[]
  sprints      Sprint[]

  @@index([organization_id])
  @@map("projects")
}

model ProjectMember {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String      @db.Uuid
  user_id    String      @db.Uuid
  role       ProjectRole @default(MEMBER)
  joined_at  DateTime    @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_members")
}

model TaskList {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String   @db.Uuid
  name       String
  sort_order Int      @default(0)
  color      String?
  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([project_id])
  @@map("task_lists")
}

model Task {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String     @db.Uuid
  project_id      String?    @db.Uuid
  task_list_id    String?    @db.Uuid
  sprint_id       String?    @db.Uuid
  parent_id       String?    @db.Uuid
  creator_id      String     @db.Uuid
  title           String
  description     String?
  status          TaskStatus @default(TODO)
  priority        Priority   @default(MEDIUM)
  type            TaskType   @default(TASK)
  story_points    Int?
  estimated_hours Decimal?   @db.Decimal(6, 2)
  actual_hours    Decimal?   @db.Decimal(6, 2)
  due_date        DateTime?
  started_at      DateTime?
  completed_at    DateTime?
  tags            String[]
  position        Decimal    @default(0) @db.Decimal(20, 10)
  custom_fields   Json       @default("{}")
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  deleted_at      DateTime?

  organization Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [project_id], references: [id])
  task_list    TaskList?     @relation(fields: [task_list_id], references: [id])
  sprint       Sprint?       @relation(fields: [sprint_id], references: [id])
  parent       Task?         @relation("TaskHierarchy", fields: [parent_id], references: [id])
  subtasks     Task[]        @relation("TaskHierarchy")
  creator      User          @relation("TaskCreator", fields: [creator_id], references: [id])
  assignments  TaskAssignment[]
  comments     TaskComment[]
  attachments  Attachment[]  @relation("TaskAttachment")

  @@index([organization_id])
  @@index([project_id])
  @@index([task_list_id])
  @@map("tasks")
}

model TaskAssignment {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id String @db.Uuid
  user_id String @db.Uuid

  task Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([task_id, user_id])
  @@map("task_assignments")
}

