  replies  ChatMessage[] @relation("MessageThread")

  @@index([channel_id])
  @@index([user_id])
  @@map("chat_messages")
}

// =============================================================================
// SHARED — ATTACHMENTS
// =============================================================================

model Attachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id       String?  @db.Uuid
  ticket_id     String?  @db.Uuid
  uploaded_by   String   @db.Uuid
  filename      String
  original_name String
  mime_type     String
  size_bytes    BigInt
  storage_key   String
  url           String?
  created_at    DateTime @default(now())

  task   Task?   @relation("TaskAttachment", fields: [task_id], references: [id])
  ticket Ticket? @relation("TicketAttachment", fields: [ticket_id], references: [id])

  @@map("attachments")
}

