  submission_id String         @db.Uuid
  step_position Int
  approver_id   String         @db.VarChar(36)
  action        ApprovalAction
  remarks       String?        @db.Text
  created_at    DateTime       @default(now())

  submission FormV2Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@index([submission_id])
  @@map("form_approval_logs")
}

model FormWebhookQueue {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id       String        @db.Uuid
  submission_id String        @db.Uuid
  webhook_url   String        @db.VarChar(500)
  payload       String        @db.Text
  attempts      Int           @default(0)
  max_attempts  Int           @default(3)
  next_at       DateTime?
  status        WebhookStatus @default(pending)
  last_error    String?       @db.Text
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  form       FormV2           @relation(fields: [form_id], references: [id], onDelete: Cascade)
  submission FormV2Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@index([status, next_at])
  @@map("form_webhook_queue")
}

model FormApiToken {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id      String     @db.Uuid
  created_by   String     @db.Uuid
  label        String     @db.VarChar(100)
  token_hash   String     @unique @db.Char(64)
  token_prefix String     @db.VarChar(8)
  scope        TokenScope @default(read)
  last_used_at DateTime?
  expires_at   DateTime?
  revoked_at   DateTime?
  created_at   DateTime   @default(now())

  form FormV2 @relation(fields: [form_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@map("form_api_tokens")
}

model FormAuditLog {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id       String          @db.Uuid
  submission_id String?         @db.Uuid
  action        FormAuditAction
  actor_id      String          @db.VarChar(50)
  actor_type    String          @db.VarChar(20)
  old_data      Json?
  new_data      Json
  ip_address    String?         @db.VarChar(45)
  user_agent    String?         @db.VarChar(255)
  created_at    DateTime        @default(now())

  form       FormV2            @relation(fields: [form_id], references: [id], onDelete: Cascade)
  submission FormV2Submission? @relation(fields: [submission_id], references: [id])

  @@index([form_id, action, created_at])
  @@map("form_audit_logs")
}

model FormVersion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  form_id        String   @db.Uuid
  version_number Int
  fields_info    Json
  changed_by     String   @db.VarChar(36)
  change_note    String?  @db.VarChar(255)
  created_at     DateTime @default(now())

  form FormV2 @relation(fields: [form_id], references: [id], onDelete: Cascade)

  @@unique([form_id, version_number])
  @@map("form_versions")
}

// =============================================================================
// Help Desk v2 — New models and enums
// Doc: 04_HELPDESK_v2.md
// All models use Hd prefix. Original non-prefixed models (Ticket, SlaPolicy, etc.)
// remain in schema.prisma and are separate.
// =============================================================================

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum HdTicketChannel {
  email
  web
  chat
  phone
  api
  social
}

enum HdTicketStatus {
  new
  open
  pending
  on_hold
  resolved
  closed
}

enum HdTicketPriority {
  low
  medium
  high
  urgent
  critical
}

enum HdTicketType {
  question
  incident
  problem
  feature_request
  task
}

enum HdSlaStatus {
  active
  breached
  completed
  paused
}

enum HdReplyType {
  public
  private
  system
}

enum HdSentVia {
  email
  chat
  api
  manual
}

enum HdAutoAssign {
  none
  round_robin
  least_active
  load_balanced
}

enum HdTeamMemberRole {
  agent
  lead
  supervisor
}

enum HdArticleStatus {
  draft
  published
  archived
}

enum HdArticleVisibility {
  internal
  external
  agents_only
}

enum HdEmailProvider {
  gmail
  outlook
  smtp
  imap
}

enum HdSatisfactionScale {
  binary
  three_point
  five_point
}

enum HdTriggerEvent {
  ticket_created
  ticket_updated
  ticket_assigned
  sla_breached
  reply_received
  ticket_resolved
  ticket_closed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model HdTicket {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String           @db.Uuid
  ticket_number     String           @db.VarChar(50)
  subject           String           @db.VarChar(500)
  description       String?          @db.Text
  status            HdTicketStatus   @default(new)
  priority          HdTicketPriority @default(medium)
  ticket_type       HdTicketType     @default(question)
  channel           HdTicketChannel  @default(web)
  category_id       String?          @db.Uuid
  team_id           String?          @db.Uuid
  assignee_id       String?          @db.Uuid
  requester_name    String?          @db.VarChar(255)
  requester_email   String?          @db.VarChar(255)
  requester_phone   String?          @db.VarChar(50)
  requester_id      String?          @db.Uuid
  sla_policy_id     String?          @db.Uuid
  sla_status        HdSlaStatus?
  sla_due_at        DateTime?
  first_response_at DateTime?
  resolved_at       DateTime?
  closed_at         DateTime?
  reopen_count      Int              @default(0)
  reply_count       Int              @default(0)
  tags              String[]
  custom_fields     Json?
  source_metadata   Json?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  deleted_at        DateTime?

  category   HdCategory?            @relation(fields: [category_id], references: [id])
  team       HdTeam?                @relation(fields: [team_id], references: [id])
  sla_policy HdSlaPolicy?           @relation(fields: [sla_policy_id], references: [id])
  replies    HdTicketReply[]
  time_logs  HdTimeLog[]
  surveys    HdSatisfactionSurvey[]

  @@unique([organization_id, ticket_number])
  @@index([organization_id])
  @@index([assignee_id])
  @@index([status])
  @@index([category_id])
  @@index([team_id])
  @@map("hd_tickets")
}

model HdTicketReply {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id        String      @db.Uuid
  author_id        String?     @db.Uuid
  reply_type       HdReplyType @default(public)
  sent_via         HdSentVia   @default(manual)
  content          String      @db.Text
  content_html     String?     @db.Text
  attachments      Json?
  email_message_id String?     @db.VarChar(500)
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  deleted_at       DateTime?

  ticket HdTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([author_id])
  @@map("hd_ticket_replies")
}

model HdSlaPolicy {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id      String    @db.Uuid
  name                 String    @db.VarChar(255)
  description          String?   @db.Text
  first_response_hours Decimal   @db.Decimal(6, 2)
  resolution_hours     Decimal   @db.Decimal(6, 2)
  business_hours_only  Boolean   @default(true)
  business_hours_id    String?   @db.Uuid
  priority_overrides   Json?
  is_default           Boolean   @default(false)
  is_active            Boolean   @default(true)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  deleted_at           DateTime?

  tickets        HdTicket[]
  business_hours HdBusinessHours? @relation(fields: [business_hours_id], references: [id])

  @@index([organization_id])
  @@map("hd_sla_policies")
}

model HdBusinessHours {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  name            String   @db.VarChar(255)
  timezone        String   @db.VarChar(100)
  schedule        Json
  holidays        Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  sla_policies HdSlaPolicy[]

  @@index([organization_id])
  @@map("hd_business_hours")
}

model HdCategory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  parent_id       String?   @db.Uuid
  color           String?   @db.VarChar(7)
  icon            String?   @db.VarChar(100)
  position        Int       @default(0)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  deleted_at      DateTime?

  parent   HdCategory?  @relation("CategoryParent", fields: [parent_id], references: [id])
  children HdCategory[] @relation("CategoryParent")
  tickets  HdTicket[]

  @@index([organization_id])
  @@index([parent_id])
  @@map("hd_categories")
}

model HdTeam {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String       @db.Uuid
  name            String       @db.VarChar(255)
  description     String?      @db.Text
  auto_assign     HdAutoAssign @default(none)
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  members HdTeamMember[]
  tickets HdTicket[]

  @@index([organization_id])
  @@map("hd_teams")
}

model HdTeamMember {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_id   String           @db.Uuid
  user_id   String           @db.Uuid
  role      HdTeamMemberRole @default(agent)
  joined_at DateTime         @default(now())

  team HdTeam @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([team_id])
  @@index([user_id])
  @@map("hd_team_members")
}

model HdCannedResponse {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String    @db.VarChar(255)
  shortcut        String?   @db.VarChar(50)
  content         String    @db.Text
  tags            String[]
  is_shared       Boolean   @default(true)
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("hd_canned_responses")
}

model HdRoutingRule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String    @db.VarChar(255)
  conditions      Json
  actions         Json
  position        Int       @default(0)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("hd_routing_rules")
}

model HdTimeLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id   String   @db.Uuid
  agent_id    String   @db.Uuid
  minutes     Int
  description String?  @db.Text
  logged_at   DateTime @default(now())
  created_at  DateTime @default(now())

  ticket HdTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([agent_id])
  @@map("hd_time_logs")
}

model HdArticle {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String              @db.Uuid
  category_id       String?             @db.Uuid
  title             String              @db.VarChar(500)
  slug              String              @db.VarChar(255)
  content           String              @db.Text
  content_html      String?             @db.Text
  status            HdArticleStatus     @default(draft)
  visibility        HdArticleVisibility @default(external)
  author_id         String              @db.Uuid
  views_count       Int                 @default(0)
  helpful_count     Int                 @default(0)
  not_helpful_count Int                 @default(0)
  tags              String[]
  published_at      DateTime?
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  deleted_at        DateTime?

  versions HdArticleVersion[]
  feedback HdArticleFeedback[]

  @@unique([organization_id, slug])
  @@index([organization_id])
  @@index([category_id])
  @@map("hd_articles")
}

model HdArticleVersion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id     String   @db.Uuid
  version_number Int
  title          String   @db.VarChar(500)
  content        String   @db.Text
  changed_by     String   @db.Uuid
  created_at     DateTime @default(now())

  article HdArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@unique([article_id, version_number])
  @@index([article_id])
  @@map("hd_article_versions")
}

model HdArticleFeedback {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id String   @db.Uuid
  user_id    String?  @db.Uuid
  is_helpful Boolean
  comment    String?  @db.Text
  created_at DateTime @default(now())

  article HdArticle @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@index([article_id])
  @@map("hd_article_feedback")
}

model HdEmailInbox {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String          @db.Uuid
  name                String          @db.VarChar(255)
  email_address       String          @db.VarChar(255)
  provider            HdEmailProvider
  credentials_enc     Json
  is_active           Boolean         @default(true)
  auto_reply          Boolean         @default(false)
  auto_reply_template String?         @db.Text
  last_synced_at      DateTime?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  deleted_at          DateTime?

  @@unique([organization_id, email_address])
  @@index([organization_id])
  @@map("hd_email_inboxes")
}

model HdSatisfactionSurvey {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id    String              @db.Uuid
  requester_id String?             @db.Uuid
  scale        HdSatisfactionScale @default(five_point)
  rating       Int
  comment      String?             @db.Text
  submitted_at DateTime            @default(now())
  created_at   DateTime            @default(now())

  ticket HdTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@unique([ticket_id])
  @@index([ticket_id])
  @@map("hd_satisfaction_surveys")
}

model HdAutomationRule {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String         @db.Uuid
  name            String         @db.VarChar(255)
  trigger_event   HdTriggerEvent
  conditions      Json
  actions         Json
  position        Int            @default(0)
  is_active       Boolean        @default(true)
  runs_count      Int            @default(0)
  last_run_at     DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  deleted_at      DateTime?

  @@index([organization_id])
  @@map("hd_automation_rules")
}

model HdRoundRobinState {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  team_id         String   @db.Uuid
  current_index   Int      @default(0)
  updated_at      DateTime @updatedAt

  @@unique([team_id])
  @@index([organization_id])
  @@map("hd_round_robin_states")
}

// =============================================================================
// Inventory v2 — New models and enums
// Doc: 06_INVENTORY_v2.md
// All models use Inv prefix. Original non-prefixed models remain in schema.prisma.
// organization_id normalized (org_id → organization_id).
// =============================================================================

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum InvBarcodeType {
  ean13
  upc
  qr
  code128
  none
}

enum InvUnitOfMeasure {
  piece
  kg
  gram
  litre
  ml
  meter
  cm
  sq_meter
  cubic_meter
  box
  carton
  dozen
  pack
  set
  pair
}

enum InvMovementType {
  receipt
  issue
  transfer_in
  transfer_out
  adjustment_in
  adjustment_out
  return_in
  return_out
  production_input
  production_output
  opening_stock
}

enum InvSerialStatus {
  in_stock
  sold
  returned
  damaged
  expired
}

enum InvTransferStatus {
  draft
  in_transit
  received
  cancelled
}

enum InvAdjustmentReason {
  count_discrepancy
  damage
  expiry
  theft
  other
}

enum InvAdjustmentStatus {
  draft
  approved
  posted
  cancelled
}

enum InvCountScope {
  full
  partial
  cycle
}

enum InvCountStatus {
  draft
  in_progress
  completed
  cancelled
}

enum InvProductionStatus {
  draft
  released
  in_progress
  completed
  cancelled
}

enum InvPriceType {
  retail
  wholesale
  special
  contract
}

enum InvLocationType {
  bin
  aisle
  shelf
  zone
  floor
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model InvProductCategory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  parent_id       String?   @db.Uuid
  position        Int       @default(0)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  parent   InvProductCategory?  @relation("InvCategoryParent", fields: [parent_id], references: [id])
  children InvProductCategory[] @relation("InvCategoryParent")
  products InvProduct[]

  @@index([organization_id])
  @@index([parent_id])
  @@map("inv_product_categories")
}

model InvProduct {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String           @db.Uuid
  category_id     String?          @db.Uuid
  name            String           @db.VarChar(255)
  sku             String           @db.VarChar(100)
  barcode         String?          @db.VarChar(100)
  barcode_type    InvBarcodeType   @default(none)
  description     String?          @db.Text
  unit_of_measure InvUnitOfMeasure @default(piece)
  cost_price      Decimal          @default(0) @db.Decimal(15, 4)
  sale_price      Decimal          @default(0) @db.Decimal(15, 4)
  currency        String           @default("USD") @db.VarChar(3)
  reorder_point   Decimal?         @db.Decimal(10, 4)
  reorder_qty     Decimal?         @db.Decimal(10, 4)
  min_stock       Decimal?         @db.Decimal(10, 4)
  max_stock       Decimal?         @db.Decimal(10, 4)
  track_serial    Boolean          @default(false)
  track_lot       Boolean          @default(false)
  has_variants    Boolean          @default(false)
  is_active       Boolean          @default(true)
  weight          Decimal?         @db.Decimal(10, 4)
  weight_unit     String?          @db.VarChar(10)
  images          String[]
  custom_fields   Json?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  deleted_at      DateTime?

  category                InvProductCategory?      @relation(fields: [category_id], references: [id])
  variants                InvProductVariant[]
  stock_levels            InvStockLevel[]
  movements               InvStockMovement[]
  bom_parents             InvBOM[]
  bom_lines               InvBOMLine[]
  invSerialNumbers        InvSerialNumber[]
  invLots                 InvLot[]
  invStockTransferLines   InvStockTransferLine[]
  invStockAdjustmentLines InvStockAdjustmentLine[]
  invPhysicalCountLines   InvPhysicalCountLine[]
  invSupplierPriceLists   InvSupplierPriceList[]
  invPriceListEntries     InvPriceListEntry[]

  @@unique([organization_id, sku])
  @@index([organization_id])
  @@index([category_id])
  @@map("inv_products")
}

model InvProductVariant {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  product_id      String    @db.Uuid
  sku             String    @db.VarChar(100)
  name            String    @db.VarChar(255)
  attributes      Json
  cost_price      Decimal   @default(0) @db.Decimal(15, 4)
  sale_price      Decimal   @default(0) @db.Decimal(15, 4)
  barcode         String?   @db.VarChar(100)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  product InvProduct @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, sku])
  @@index([organization_id])
  @@index([product_id])
  @@map("inv_product_variants")
}

model InvWarehouse {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String    @db.Uuid
  name            String    @db.VarChar(255)
  code            String    @db.VarChar(50)
  address         Json?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  locations    InvLocation[]
  stock_levels InvStockLevel[]

  @@unique([organization_id, code])
  @@index([organization_id])
  @@map("inv_warehouses")
}

model InvLocation {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  warehouse_id    String          @db.Uuid
  name            String          @db.VarChar(255)
  code            String?         @db.VarChar(50)
  location_type   InvLocationType @default(bin)
  parent_id       String?         @db.Uuid
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  deleted_at      DateTime?

  warehouse InvWarehouse  @relation(fields: [warehouse_id], references: [id])
  parent    InvLocation?  @relation("LocationParent", fields: [parent_id], references: [id])
  children  InvLocation[] @relation("LocationParent")

  @@index([organization_id])
  @@index([warehouse_id])
  @@map("inv_locations")
}

model InvStockLevel {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  product_id      String   @db.Uuid
  variant_id      String?  @db.Uuid
  warehouse_id    String   @db.Uuid
  location_id     String?  @db.Uuid
  quantity        Decimal  @default(0) @db.Decimal(10, 4)
  reserved_qty    Decimal  @default(0) @db.Decimal(10, 4)
  available_qty   Decimal  @default(0) @db.Decimal(10, 4)
  avg_cost        Decimal  @default(0) @db.Decimal(15, 4)
  updated_at      DateTime @updatedAt

  product   InvProduct   @relation(fields: [product_id], references: [id])
  warehouse InvWarehouse @relation(fields: [warehouse_id], references: [id])

  @@unique([product_id, variant_id, warehouse_id, location_id])
  @@index([organization_id])
  @@index([product_id])
  @@index([warehouse_id])
  @@map("inv_stock_levels")
}

model InvStockMovement {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  product_id      String          @db.Uuid
  variant_id      String?         @db.Uuid
  warehouse_id    String          @db.Uuid
  location_id     String?         @db.Uuid
  movement_type   InvMovementType
