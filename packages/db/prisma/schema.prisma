// organization_id normalized (org_id → organization_id).
// =============================================================================

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AccAccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum AccNormalBalance {
  debit
  credit
}

enum AccJournalStatus {
  draft
  posted
  voided
}

enum AccJournalSource {
  manual
  invoice
  payment
  bill
  expense
  payroll
  bank_import
  recurring
  depreciation
}

enum AccInvoiceStatus {
  draft
  sent
  partial
  paid
  overdue
  voided
  written_off
}

enum AccInvoiceType {
  standard
  credit_note
  debit_note
  proforma
}

enum AccPaymentTerms {
  due_on_receipt
  net_7
  net_15
  net_30
  net_60
  net_90
  custom
}

enum AccPaymentType {
  invoice_payment
  advance
  refund
  credit_note_application
}

enum AccPaymentMethod {
  bank_transfer
  cash
  cheque
  credit_card
  upi
  online
  other
}

enum AccBillStatus {
  draft
  received
  partial
  paid
  overdue
  voided
}

enum AccTaxType {
  gst
  igst
  cgst
  sgst
  vat
  sales_tax
  custom
}

enum AccBankAccountType {
  checking
  savings
  credit_card
  loan
  investment
}

enum AccBankTransactionType {
  debit
  credit
}

enum AccBankTransactionStatus {
  unreconciled
  reconciled
  excluded
}

enum AccRecurringFrequency {
  daily
